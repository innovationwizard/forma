{
  "name": "forma",
  "version": "0.1.0",
  "private": true,
  "description": "FORMA — Condominio Santa Elena Budget Tracker. Pilot for FORMA's holding-wide normalization initiative.",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "verify:rbac": "tsx scripts/verify-rbac.ts",
    "verify:rls": "tsx scripts/verify-rls.ts",
    "xlsx:parse": "tsx scripts/xlsx/parse.ts",
    "seed": "tsx scripts/seed/index.ts",
    "verify:calc": "tsx scripts/verify-calc.ts",
    "parity:report": "tsx scripts/parity/index.ts",
    "banguat:backfill": "tsx scripts/banguat/backfill.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"scripts/**/*.ts\" \"*.{ts,tsx,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\" \"scripts/**/*.ts\" \"*.{ts,tsx,mjs,json,md}\""
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
