# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# Every variable listed here is required for the app to boot (see src/lib/env.ts).
# Missing required values cause the app to fail fast at startup, not at runtime.

# ─── Supabase (Batch 2) ──────────────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API Keys.
# The publishable + secret pair is Supabase's current key system; the legacy
# anon / service_role pair is deprecated and must not be used.
#
# NEXT_PUBLIC_SUPABASE_URL: project URL, e.g. https://xxxx.supabase.co.
#   Inlined into the client bundle (SSR pattern needs it on both sides).
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY: starts `sb_publishable_…`. Safe to
#   expose to the browser; replaces the deprecated anon key.
# SUPABASE_SECRET_KEY: starts `sb_secret_…`. Server-only, never exposed;
#   bypasses RLS. Replaces the deprecated service_role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ─── Database (Batch 2 — Prisma) ─────────────────────────────────────────────
# Both DATABASE_URL and DIRECT_URL use the Supabase Session pooler in this
# project. Reason: in our environment only the Session pooler is IPv4
# compatible — Direct connection (`db.<ref>.supabase.co:5432`) and Transaction
# pooler (port 6543) are both IPv6-only. Session pooler is session-mode (not
# transaction-mode) so it supports the prepared statements + advisory locks +
# DDL that Prisma needs for both runtime queries and migrations.
#
# Format (paste verbatim from Supabase dashboard → Project Settings → Database
# → Connection string → Session pooler):
#   postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
#
# DATABASE_URL: used by the app at runtime (Prisma normal queries).
# DIRECT_URL: used by `prisma migrate`. Same URL is correct here — Session
#   pooler keeps connections open per session, so migrations work through it.
DATABASE_URL=
DIRECT_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
# NODE_ENV: development | production | test (Next.js manages this; do not set manually in .env.local)
# NEXT_PUBLIC_APP_NAME: shown in the browser tab, header, etc.
NEXT_PUBLIC_APP_NAME=FORMA — Santa Elena
