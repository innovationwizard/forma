# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# Every variable listed here is required for the app to boot (see src/lib/env.ts).
# Missing required values cause the app to fail fast at startup, not at runtime.

# ─── Supabase (Batch 2) ──────────────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API.
# SUPABASE_URL: project URL, e.g. https://xxxx.supabase.co
# SUPABASE_ANON_KEY: public anon key (safe to expose to the browser)
# SUPABASE_SERVICE_ROLE_KEY: server-only, never exposed; bypasses RLS
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (Batch 2 — Prisma) ─────────────────────────────────────────────
# DATABASE_URL: pooled connection (PgBouncer). Use for app runtime.
# DIRECT_URL: direct (non-pooled) connection. Use for migrations.
# Both come from Supabase dashboard → Project Settings → Database → Connection string.
DATABASE_URL=
DIRECT_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
# NODE_ENV: development | production | test (Next.js manages this; do not set manually in .env.local)
# NEXT_PUBLIC_APP_NAME: shown in the browser tab, header, etc.
NEXT_PUBLIC_APP_NAME=FORMA — Santa Elena
